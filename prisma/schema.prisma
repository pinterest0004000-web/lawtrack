generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model LawyerCase {
  id            String   @id @default(cuid())
  caseId        String
  lawyerName    String
  partyName     String
  opponentName  String
  caseType      String   @default("")
  section       String   @default("")
  policeStation String   @default("")
  enteringDate  String   @default("")
  nextDate      String   @default("")
  phone         String   @default("")
  judgeRemarks  String   @default("")
  pendingFee    Float    @default(0)
  totalFeeReceived Float  @default(0)
  history       String   @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([caseId])
}

model Expense {
  id            String   @id @default(cuid())
  caseId        String
  lawyerName    String
  partyName     String
  description   String
  amount        Float
  date          String
  category      String   @default("case_expense")
  createdAt     DateTime @default(now())
}